# SRSRAN GNB
SRS_GNB_IP=172.22.0.37

# IBCF 
IBCF_IP=172.22.0.140

# GRAFANA
GRAFANA_IP=172.22.0.39
GRAFANA_USERNAME=open5gs
GRAFANA_PASSWORD=open5gs

# OCS
OCS_IP=172.22.0.40
OCS_BIND_PORT=3872

# OSMOEPDG
OSMOEPDG_IP=172.22.0.41

# SWU CLIENT
SWU_CLIENT_IP=172.22.0.42

# UE IPv4 Subnet Range for APN=internet
UE_IPV4_INTERNET=192.168.100.0/24

# UE IPv4 Subnet Range for APN=ims
UE_IPV4_IMS=192.168.101.0/24

# UE IPv6 Subnet Ranges (must match the SMF/UPF session pools). Used for the
# dual-stack return routes (pcscf/rtpengine -> UPF). NOTE: 2001:230:* are example
# prefixes; swap for a routable prefix when a real public IPv6 upstream exists.
UE_IPV6_INTERNET=2001:230:cafe::/48
UE_IPV6_IMS=2001:230:babe::/48

# Maximum Number of UEs
MAX_NUM_UE=1024

# --- Static IPv6 (ULA, mirrors IPv4 host octet) for migration-stable addressing ---
